# Copy this file to .env and fill in real values before running `docker compose up`.
# .env is gitignored — never commit real secrets.

# SQL Server (single instance, shared "tthcm" database, schema-per-service). Must satisfy SQL
# Server's password complexity policy: 8+ chars, with upper+lower+digit+symbol, or the mssql
# container will refuse to start.
MSSQL_SA_PASSWORD=Change-Me-To-A-Strong-Password1!

# HMAC signing key every service uses to issue/validate JWTs — must be identical across all
# services and the gateway. Generate a real random 32+ byte value for anything beyond local dev,
# e.g.: openssl rand -base64 48
JWT_SIGNING_KEY=dev-only-signing-key-do-not-use-in-production-min-32-chars

# Platform-owned Groq API key used by ai-service for every AI call (chat, lecture narration,
# oral grading, question extraction) — never a per-user key, see ai-service's GroqOptions remarks.
GROQ_API_KEY=

# Frontend origin allowed through CORS on the gateway (and each service, defense in depth).
# Comma-not-needed: this compose file only wires a single origin; add more by editing
# docker-compose.yml directly if the frontend is served from multiple domains.
FRONTEND_ORIGIN=http://localhost:5500

# Requests/minute per user allowed through the gateway's /api/v1/ai/** rate limiter.
AI_RATE_LIMIT_PER_MINUTE=10

# Seed 3 demo accounts (student@demo.tthcm / teacher@demo.tthcm / admin@demo.tthcm, password
# Demo123!) on auth-service startup if the users table is empty. Set to false for anything
# resembling production.
SEED_DEMO_ACCOUNTS=true
