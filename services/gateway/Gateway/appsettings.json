{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "tthcm-platform",
    "Audience": "tthcm-services"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Seq": {
    "Url": ""
  },
  "RateLimiting": {
    "Ai": {
      "PermitLimit": 10
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "content-route": {
        "ClusterId": "content-cluster",
        "Match": { "Path": "/api/v1/content/{**catch-all}" }
      },
      "quiz-route": {
        "ClusterId": "quiz-cluster",
        "Match": { "Path": "/api/v1/quiz/{**catch-all}" }
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "ai",
        "Match": { "Path": "/api/v1/ai/{**catch-all}" }
      },
      "progress-route": {
        "ClusterId": "progress-cluster",
        "Match": { "Path": "/api/v1/progress/{**catch-all}" }
      },
      "admin-route": {
        "ClusterId": "admin-cluster",
        "AuthorizationPolicy": "admin-only",
        "Match": { "Path": "/api/v1/admin/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "HealthCheck": { "Active": { "Enabled": true, "Interval": "00:00:15", "Timeout": "00:00:05", "Path": "/health" } },
        "Destinations": { "d1": { "Address": "http://auth-service:8080" } }
      },
      "content-cluster": {
        "HealthCheck": { "Active": { "Enabled": true, "Interval": "00:00:15", "Timeout": "00:00:05", "Path": "/health" } },
        "Destinations": { "d1": { "Address": "http://content-service:8080" } }
      },
      "quiz-cluster": {
        "HealthCheck": { "Active": { "Enabled": true, "Interval": "00:00:15", "Timeout": "00:00:05", "Path": "/health" } },
        "Destinations": { "d1": { "Address": "http://quiz-service:8080" } }
      },
      "ai-cluster": {
        "HealthCheck": { "Active": { "Enabled": true, "Interval": "00:00:15", "Timeout": "00:00:05", "Path": "/health" } },
        "Destinations": { "d1": { "Address": "http://ai-service:8080" } }
      },
      "progress-cluster": {
        "HealthCheck": { "Active": { "Enabled": true, "Interval": "00:00:15", "Timeout": "00:00:05", "Path": "/health" } },
        "Destinations": { "d1": { "Address": "http://progress-service:8080" } }
      },
      "admin-cluster": {
        "HealthCheck": { "Active": { "Enabled": true, "Interval": "00:00:15", "Timeout": "00:00:05", "Path": "/health" } },
        "Destinations": { "d1": { "Address": "http://admin-service:8080" } }
      }
    }
  }
}
